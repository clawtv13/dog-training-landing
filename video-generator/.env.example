# Video Generator Configuration

# Pexels API Key (free at https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Key (free at https://pixabay.com/api/docs/)
# Used for videos (fallback) and music
PIXABAY_API_KEY=your_pixabay_api_key_here

# OpenRouter API Key (for LLM scene parsing)
# Optional - will use simple parsing fallback if not set
OPENROUTER_API_KEY=your_openrouter_key_here

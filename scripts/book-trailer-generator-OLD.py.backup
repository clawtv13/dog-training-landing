    """Get platform-specific settings"""
    
    configs = {
        'tiktok': {
            'name': 'TikTok',
            'duration': 60,
            'hashtag_count': 7,
            'requirements': '60s MAX, fast cuts (2-3/sec), trending audio, hook in 3s, text 8 words max'
        },
        'instagram': {
            'name': 'Instagram Reels',
            'duration': 90,
            'hashtag_count': 15,
            'requirements': '90s MAX, polished aesthetic, original audio OK, clean overlays, hashtags in comments'
        },
        'youtube': {
            'name': 'YouTube Shorts',
            'duration': 60,
            'hashtag_count': 5,
            'requirements': '60s MAX, SEO description, #shorts mandatory, pinned comment CTA, copyright-safe audio'
        }
    }
    
    return configs.get(platform, configs['tiktok'])

# ============================================================================
# PROMPT GENERATION
# ============================================================================

def build_system_prompt(formula: Dict, platform: Dict, context: Dict) -> str:
    """Build comprehensive system prompt for generation"""
    
    formula_structure = "\n".join([
        f"SCENE {i+1} ({scene['timing']}): {scene.get('purpose', scene.get('hook_type', 'Scene'))} - {scene.get('text_template', '')}"
        for i, (scene_key, scene) in enumerate(formula['structure'].items())
    ])
    
    return f"""You are a viral true crime short-form video expert creating trailer prompts for book marketing.

**FORMULA:** {formula['name']} (Target Retention: {formula['retention']}%)
**PLATFORM:** {platform['name']} ({platform['duration']}s max)

**BOOK CONTEXT:**
- Victim: {context.get('victim_name', 'Unknown')}
- Location: {context.get('location', 'Unknown')}
- Years unsolved: {context.get('years_unsolved', 'Multiple')}
- Forensic method: {context.get('forensic_method', 'Investigation')}
- Relationship: {context.get('killer_relationship', 'Unknown')}

**FORMULA STRUCTURE:**
{formula_structure}

**PLATFORM REQUIREMENTS:**
{platform['requirements']}

**COMPLIANCE (CRITICAL):**
- NO graphic violence or gore
- Victim-respectful framing ALWAYS
- No killer glorification
- Family-approval test: Would victim's family object?
- Focus on justice, not sensationalism

**OUTPUT FORMAT:**
Generate a complete video prompt with:

1. **HOOK** (first line that appears in feed)
2. **SCENE-BY-SCENE BREAKDOWN** with exact timing
3. **TEXT OVERLAYS** per scene (specific words to appear on screen)
4. **VISUAL SUGGESTIONS** (what viewer sees)
5. **AUDIO/MUSIC** recommendations
6. **HASHTAGS** ({platform['hashtag_count']} total)
7. **TITLE**
8. **DESCRIPTION**
9. **PINNED COMMENT** (CTA for Amazon link)

**CTA:** Always drive to "link in bio" for Amazon book purchase.

Generate the complete trailer prompt now."""

def generate_trailer_prompt(book: Dict, formula_key: str, platform: str, compact_mode: bool = False) -> Optional[str]:
    """Generate video prompt via OpenRouter"""
    
    formulas = load_formulas()
    formula = formulas[formula_key]
    platform_config = get_platform_config(platform)
    book_context = extract_book_context(book['research_file'])
    
    system_prompt = build_system_prompt(formula, platform_config, book_context)
    
    mode_str = "COMPACT" if compact_mode else "detailed"
    print(f"   🎬 Generating {platform} prompt ({mode_str})...")
    
    try:
        response = requests.post(
            "https://openrouter.ai/api/v1/chat/completions",
            headers={
                "Authorization": f"Bearer {OPENROUTER_KEY}",
                "Content-Type": "application/json"
            },
            json={
                "model": "anthropic/claude-sonnet-4",
                "messages": [
                    {"role": "user", "content": system_prompt}
                ],
                "temperature": 0.8,
                "max_tokens": 2048
            },
            timeout=90
        )
        
        if response.status_code == 200:
            result = response.json()
            generated = result["choices"][0]["message"]["content"]
            
            # Refine for CapCut AI clarity
            if REFINEMENT_AVAILABLE:
                refine_type = "Compacting" if compact_mode else "Enhancing"
                print(f"   🔄 {refine_type} {platform} prompt...")
                generated = refine_prompt(generated, platform, compact_mode=compact_mode)
                if compact_mode:
                    char_count = len(generated)
                    print(f"   ✨ Compacted to {char_count} chars")
                else:
                    print(f"   ✨ Enhanced (+30% specificity)")
            
            return generated
        else:
            print(f"   ✗ OpenRouter error: {response.status_code}")
            return None
            
    except Exception as e:
        print(f"   ✗ Error: {e}")
        return None

def generate_all_platforms(book: Dict, formula_key: str, compact_mode: bool = False) -> Dict[str, str]:
    """Generate prompts for all 3 platforms"""
    
    platforms = ['tiktok', 'instagram', 'youtube']
    results = {}
    
    mode_str = " (COMPACT MODE)" if compact_mode else ""
    print(f"\n📹 Generating trailer prompts for: {book['name']}{mode_str}")
    print(f"🎯 Formula: {formula_key}")
    print(f"📱 Platforms: TikTok, Instagram, YouTube\n")
    
    for platform in platforms:
        prompt = generate_trailer_prompt(book, formula_key, platform, compact_mode=compact_mode)
        if prompt:
            results[platform] = prompt
            char_count = len(prompt)
            status = "✓" if not compact_mode or char_count <= 3000 else "⚠️"
            print(f"   {status} {platform.title()} prompt generated ({char_count} chars)")
        else:
            print(f"   ✗ {platform.title()} failed")
    
    return results

# ============================================================================
# COMPLIANCE VALIDATION
# ============================================================================

def validate_compliance(prompt: str) -> Tuple[bool, List[str]]:
    """Check prompt against compliance filters"""
    
    compliance = load_compliance()
    issues = []
    
    prompt_lower = prompt.lower()
    
    # Check prohibited content
    for category, rules in compliance['prohibited_content'].items():
        if 'keywords' in rules:
            for keyword in rules['keywords']:
                if keyword in prompt_lower:
                    issues.append(f"Prohibited: {keyword} ({category})")
    
    # Check required elements
    required = ['victim', 'justice']
    for term in required:
        if term not in prompt_lower:
            issues.append(f"Missing required element: {term}")
    
    return (len(issues) == 0, issues)

# ============================================================================
# OUTPUT FORMATTING
# ============================================================================

def format_output(book: Dict, formula: str, results: Dict) -> str:
    """Format results for Telegram/file delivery"""
    
    formulas = load_formulas()
    formula_info = formulas[formula]
    
    output = f"""📹 **BOOK TRAILER PROMPTS**

📚 **Book:** {book['name']}
🎯 **Formula:** {formula_info['name']} ({formula_info['retention']}% retention)
📊 **Platforms:** {', '.join(results.keys())}

{'='*60}

"""
    
    for platform, prompt in results.items():
        output += f"""**{platform.upper()}:**

{prompt}

{'='*60}

"""
    
    output += f"""**Generated:** {datetime.now().strftime('%Y-%m-%d %H:%M UTC')}
**Ready for:** CapCut AI, Runway, Luma, or manual production
"""
    
    return output

def save_output(book: Dict, formula: str, results: Dict):
    """Save results to file"""
    
    timestamp = datetime.now().strftime('%Y%m%d-%H%M')
    slug = book['slug']
    
    output_file = OUTPUT_DIR / f"{timestamp}-{slug}-{formula}.txt"
    
    content = format_output(book, formula, results)
    
    with open(output_file, 'w') as f:
        f.write(content)
    
    print(f"\n💾 Saved to: {output_file}")
    return output_file

# ============================================================================
# TELEGRAM DELIVERY
# ============================================================================

def send_telegram(message: str):
    """Deliver prompt via Telegram"""
    
    if not TELEGRAM_BOT or not TELEGRAM_CHAT:
        print("⚠️  Telegram not configured (missing env vars)")
        return False
    
    try:
        # Try with Markdown first
        response = requests.post(
            f"https://api.telegram.org/bot{TELEGRAM_BOT}/sendMessage",
            json={
                "chat_id": TELEGRAM_CHAT,
                "text": message,
                "parse_mode": "Markdown"
            },
            timeout=10
        )
        
        # If markdown fails, retry without parse_mode
        if response.status_code != 200:
            response = requests.post(
                f"https://api.telegram.org/bot{TELEGRAM_BOT}/sendMessage",
                json={
                    "chat_id": TELEGRAM_CHAT,
                    "text": message
                },
                timeout=10
            )
        
        if response.status_code == 200:
            print("✅ Sent to Telegram")
            return True
        else:
            print(f"⚠️  Telegram error: {response.status_code}")
            return False
            
    except Exception as e:
        print(f"⚠️  Telegram failed: {e}")
        return False

# ============================================================================
# CLI
# ============================================================================

def main():
    parser = argparse.ArgumentParser(
        description="Generate viral book trailer prompts for Mind Crimes",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s                                    # Auto-select book and formula
  %(prog)s --book "killer-clown"              # Specific book
  %(prog)s --book "killer-clown" --formula villain_reveal  # Force formula
  %(prog)s --platform tiktok                  # Single platform
  %(prog)s --list-books                       # Show available books
  %(prog)s --list-formulas                    # Show available formulas
  %(prog)s --dry-run                          # Preview without saving state
        """
    )
    
    parser.add_argument("--book", help="Force specific book (partial match)")
    parser.add_argument("--formula", 
                        choices=['news_hook', 'evidence_reveal', 'villain_reveal',
                                'victim_story', 'science_angle', 'comparison_hook'],
                        help="Force specific formula (default: auto-match)")
    parser.add_argument("--platform", 
                        choices=['tiktok', 'instagram', 'youtube', 'all'],
                        default='all',
                        help="Target platform (default: all)")
    parser.add_argument("--compact", action="store_true",
                        help="Generate ultra-compact prompts (<3K chars) for CapCut limits")
    parser.add_argument("--list-books", action="store_true",
                        help="List available books and exit")
    parser.add_argument("--list-formulas", action="store_true",
                        help="List available formulas and exit")
    parser.add_argument("--dry-run", action="store_true",
                        help="Generate but don't save state")
    parser.add_argument("--no-telegram", action="store_true",
                        help="Skip Telegram notification")
    
    args = parser.parse_args()
    
    # List commands
    if args.list_formulas:
        formulas = load_formulas()
        print("\n📋 Available Formulas:\n")
        for key, formula in formulas.items():
            print(f"  {key:20} - {formula['name']:20} ({formula['retention']}% retention)")
            print(f"  {'':20}   Best for: {formula['best_for']}\n")
        return
    
    if args.list_books:
        books = discover_books()
        print(f"\n📚 Available Books ({len(books)}):\n")
        for book in books:
            print(f"  - {book['name']} ({book['slug']})")
        print()
        return
    
    # Main generation flow
    print("\n" + "="*60)
    print("📹 BOOK TRAILER GENERATOR - Mind Crimes")
    print("="*60)
    
    # Check API key
    if not OPENROUTER_KEY:
        print("\n✗ Error: OPENROUTER_API_KEY not set")
        sys.exit(1)
    
    # Discover books
    books = discover_books()
    if not books:
        print("\n✗ No books found in", BOOKS_DIR)
        sys.exit(1)
    
    # Select book
    book = select_book(books, args.book)
    if not book:
        print("\n✗ No suitable book found")
        sys.exit(1)
    
    # Extract metadata and match formula
    metadata = extract_book_metadata(book['research_file'])
    formula = args.formula or match_book_to_formula(metadata)
    
    print(f"\n📖 Selected: {book['name']}")
    print(f"🎯 Formula: {formula} (auto-matched)" if not args.formula else f"🎯 Formula: {formula} (forced)")
    
    # Generate prompts
    if args.platform == 'all':
        results = generate_all_platforms(book, formula, compact_mode=args.compact)
    else:
        prompt = generate_trailer_prompt(book, formula, args.platform, compact_mode=args.compact)
        results = {args.platform: prompt} if prompt else {}
    
    if not results:
        print("\n✗ No prompts generated")
        sys.exit(1)
    
    # Validate compliance
    print("\n🔒 Checking compliance...")
    for platform, prompt in results.items():
        is_valid, issues = validate_compliance(prompt)
        if not is_valid:
            print(f"   ⚠️  {platform}: {len(issues)} issues")
            for issue in issues:
                print(f"      - {issue}")
        else:
            print(f"   ✓ {platform}: Compliant")
    
    # Save output
    output_file = save_output(book, formula, results)
    
    # Format message
    output_text = format_output(book, formula, results)
    
    # Print to console
    print("\n" + "="*60)
    print(output_text)
    print("="*60)
    
    # Send to Telegram
    if not args.no_telegram:
        send_telegram(output_text)
    
    # Save state
    if not args.dry_run:
        save_state(book['name'], formula, list(results.keys()))
        print(f"\n✅ State saved (7-day cooldown active)")
    else:
        print(f"\n⚠️  Dry run - state not saved")
    
    print(f"\n✅ Complete!")

if __name__ == "__main__":
    main()

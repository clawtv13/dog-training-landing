  ============================================================================
  SECTION C: COUNTDOWN TIMER - HTML
  ============================================================================
{% endcomment %}

<div class="vz-countdown" id="vzCountdown">
  <div class="vz-countdown__container">
    <span class="vz-countdown__label">🔥 Sale ends in:</span>
    
    <div class="vz-countdown__timer">
      <div class="vz-countdown__unit">
        <span class="vz-countdown__number" id="vzCountdownHours">00</span>
        <span class="vz-countdown__text">hrs</span>
      </div>
      <span class="vz-countdown__separator">:</span>
      <div class="vz-countdown__unit">
        <span class="vz-countdown__number" id="vzCountdownMinutes">00</span>
        <span class="vz-countdown__text">min</span>
      </div>
      <span class="vz-countdown__separator">:</span>
      <div class="vz-countdown__unit">
        <span class="vz-countdown__number" id="vzCountdownSeconds">00</span>
        <span class="vz-countdown__text">sec</span>
      </div>
    </div>
    
    <p class="vz-countdown__subtext">Don't miss 30% off — Back to $99 after timer ends</p>
  </div>
</div>

<script>
(function() {
  // Countdown Timer - ends at midnight tonight (user's timezone)
  function initCountdown() {
    const hoursEl = document.getElementById('vzCountdownHours');
    const minutesEl = document.getElementById('vzCountdownMinutes');
    const secondsEl = document.getElementById('vzCountdownSeconds');
    
    if (!hoursEl || !minutesEl || !secondsEl) return;
    
    function getEndTime() {
      const now = new Date();
      const end = new Date(now);
      end.setHours(23, 59, 59, 999);
      return end;
    }
    
    function updateCountdown() {
      const now = new Date();
      const end = getEndTime();
      const diff = end - now;
      
      if (diff <= 0) {
        hoursEl.textContent = '00';
        minutesEl.textContent = '00';
        secondsEl.textContent = '00';
        return;
      }
      
      const hours = Math.floor(diff / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);
      
      hoursEl.textContent = hours.toString().padStart(2, '0');
      minutesEl.textContent = minutes.toString().padStart(2, '0');
      secondsEl.textContent = seconds.toString().padStart(2, '0');
    }
    
    updateCountdown();
    setInterval(updateCountdown, 1000);
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCountdown);
  } else {
    initCountdown();
  }
})();
</script>



<div class="vz-exit-popup" id="vzExitPopup">
  <div class="vz-exit-popup__content">
    <button class="vz-exit-popup__close" aria-label="Close popup" id="vzExitPopupClose">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    
    <div class="vz-exit-popup__icon">
      {% if product.featured_image %}
        <img 
          src="{{ product.featured_image | image_url: width: 120 }}" 
          alt="{{ product.title | escape }}"
          loading="lazy"
        >
      {% endif %}
    </div>
    
    <h2 class="vz-exit-popup__title">Wait! Don't Leave Yet</h2>
    <p class="vz-exit-popup__subtitle">
      Your skin transformation is just a click away. Here's something special for you:
    </p>
    
    <div class="vz-exit-popup__offer">
      <p class="vz-exit-popup__offer-text">
        Use code <span class="vz-exit-popup__offer-code">GLOW10</span> for an extra 10% off
      </p>
    </div>
    
    <a href="#product-form" class="vz-exit-popup__cta" id="vzExitPopupCta">
      Claim My Discount
    </a>
    
    <button class="vz-exit-popup__dismiss" id="vzExitPopupDismiss">
      No thanks, I'll pay full price
    </button>
  </div>
</div>

<script>
(function() {
  // Exit Popup - Trigger on exit intent (desktop) or scroll up (mobile)
  function initExitPopup() {
    const popup = document.getElementById('vzExitPopup');
    const closeBtn = document.getElementById('vzExitPopupClose');
    const ctaBtn = document.getElementById('vzExitPopupCta');
    const dismissBtn = document.getElementById('vzExitPopupDismiss');
    
    if (!popup) return;
    
    const STORAGE_KEY = 'vz_exit_popup_shown';
    const COOLDOWN_HOURS = 24;
    
    // Check if popup was recently shown
    function wasRecentlyShown() {
      try {
        const timestamp = localStorage.getItem(STORAGE_KEY);
        if (!timestamp) return false;
        const hoursSince = (Date.now() - parseInt(timestamp)) / (1000 * 60 * 60);
        return hoursSince < COOLDOWN_HOURS;
      } catch (e) {
        return false;
      }
    }
    
    function markAsShown() {
      try {
        localStorage.setItem(STORAGE_KEY, Date.now().toString());
      } catch (e) {}
    }
    
    function showPopup() {
      if (wasRecentlyShown()) return;
      popup.classList.add('is-visible');
      document.body.style.overflow = 'hidden';
      markAsShown();
    }
    
    function hidePopup() {
      popup.classList.remove('is-visible');
      document.body.style.overflow = '';
    }
    
    // Exit intent detection (desktop)
    function handleMouseLeave(e) {
      if (e.clientY <= 0) {
        showPopup();
        document.removeEventListener('mouseleave', handleMouseLeave);
      }
    }
    
    // Scroll up detection (mobile) - removed as it can be annoying
    // Instead, we'll use a 60-second delay for mobile
    let mobileTimeout = null;
    
    function initTriggers() {
      if (wasRecentlyShown()) return;
      
      // Desktop: exit intent
      if (window.innerWidth > 749) {
        document.addEventListener('mouseleave', handleMouseLeave);
      } else {
        // Mobile: show after 60 seconds of browsing
        mobileTimeout = setTimeout(showPopup, 60000);
      }
    }
    
    // Event listeners
    closeBtn?.addEventListener('click', hidePopup);
    dismissBtn?.addEventListener('click', hidePopup);
    
    ctaBtn?.addEventListener('click', (e) => {
      hidePopup();
      // Let the link navigate normally
    });
    
    // Close on overlay click
    popup.addEventListener('click', (e) => {
      if (e.target === popup) hidePopup();
    });
    
    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && popup.classList.contains('is-visible')) {
        hidePopup();
      }
    });
    
    // Initialize after a short delay to let page load
    setTimeout(initTriggers, 5000);
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initExitPopup);
  } else {
    initExitPopup();
  }
})();
</script>

<div class="vz-sticky-cart" id="vzStickyCart">
  <div class="vz-sticky-cart__container">
    <div class="vz-sticky-cart__image">
      {% if product.featured_image %}
        <img 
          src="{{ product.featured_image | image_url: width: 100 }}" 
          alt="{{ product.title | escape }}"
          loading="lazy"
        >
      {% endif %}
    </div>
    
    <div class="vz-sticky-cart__info">
      <h4 class="vz-sticky-cart__title">{{ product.title }}</h4>
      <div class="vz-sticky-cart__price">
        <span class="vz-sticky-cart__price-current">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="vz-sticky-cart__price-compare">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>
    </div>
    
    <button 
      type="submit" 
      class="vz-sticky-cart__button"
      form="product-form-{{ section.id }}"
    >
      Add to Cart
    </button>
  </div>
</div>

<script>
(function() {
  // Sticky Cart - Show when product form is out of viewport
  function initStickyCart() {
    const stickyCart = document.getElementById('vzStickyCart');
    const productForm = document.querySelector('[data-type="add-to-cart-form"]');
    
    if (!stickyCart || !productForm) return;
    
    // Only show on mobile (handled by CSS, but we still need scroll logic)
    let isVisible = false;
    
    function checkVisibility() {
      const formRect = productForm.getBoundingClientRect();
      const shouldShow = formRect.bottom < 0 || formRect.top > window.innerHeight;
      
      if (shouldShow !== isVisible) {
        isVisible = shouldShow;
        stickyCart.classList.toggle('is-visible', isVisible);
      }
    }
    
    // Throttled scroll handler
    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          checkVisibility();
          ticking = false;
        });
        ticking = true;
      }
    }
    
    window.addEventListener('scroll', onScroll, { passive: true });
    checkVisibility();
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStickyCart);
  } else {
    initStickyCart();
  }
})();
</script>



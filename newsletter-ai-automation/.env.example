# AI Automation Builder - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# REQUIRED - Newsletter Platform
# ============================================================================

# Beehiiv API credentials
# Get from: https://app.beehiiv.com/settings/integrations/api
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=your_publication_id_here

# OpenRouter API (for Claude Sonnet 4)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ============================================================================
# OPTIONAL - Enhanced Research
# ============================================================================

# Reddit API (for subreddit monitoring)
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Twitter Bearer Token (for influencer monitoring)
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# GitHub Personal Access Token (for trending repos)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token

# Product Hunt API (for new tool discovery)
# Get from: https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_KEY=your_producthunt_api_key

# ============================================================================
# OPTIONAL - Notifications
# ============================================================================

# Telegram Bot (for draft notifications)
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============================================================================
# CONFIGURATION
# ============================================================================

# Newsletter settings
NEWSLETTER_NAME="AI Automation Builder"
TARGET_WORD_COUNT=800

# Research settings
RESEARCH_LOOKBACK_DAYS=7
MIN_CONTENT_SCORE=28

# Publishing schedule
PUBLISH_DAY=5  # 5 = Friday
PUBLISH_HOUR=8  # 08:00 UTC
